{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "paths": {
      "@shared/*": ["../*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "../lib/db/**/*.ts", "../types/**/*.ts"]
}
